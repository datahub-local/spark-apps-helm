{
  "packages": [
    "k3d@latest",
    "k9s@latest",
    "kubernetes-helm@latest",
    "helmfile@latest",
    "chart-testing@latest",
    "renovate@latest"
  ],
  "shell": {
    "scripts": {
      "start-k8s": ".github/ci/start_k8s.sh",
      "stop-k8s": ".github/ci/stop_k8s.sh",
      "test-k8s": ".github/ci/test_k8s.sh",
      "test-check": ".github/ci/test_check.sh",
      "test-install": ".github/ci/test_install.sh",
      "test-unit": ".github/ci/test_unit.sh",
      "test-delete": "kubectl delete ns --force servarr || true",
      "init-charts": "./.github/ci/init_charts.sh",
      "lint": "extra_args=\"\"; if [[ \"${CACHE_HIT:-false}\" == \"true\" ]]; then extra_args=\"--skip-helm-dependencies\"; fi; ct lint --chart-dirs=. --charts=spark-apps --validate-maintainers=false ${extra_args}",
      "test-renovate": "LOG_LEVEL=debug renovate --platform=local --dry-run=full"
    }
  }
}