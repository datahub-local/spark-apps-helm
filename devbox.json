{
  "packages": [
    "k3d@latest",
    "k9s@latest",
    "kubernetes-helm@latest",
    "helmfile@latest",
    "chart-testing@latest",
    "renovate@latest"
  ],
  "shell": {
    "scripts": {
      "start_k8s": "./.github/ci/start_k8s.sh",
      "stop_k8s": "./.github/ci/stop_k8s.sh",
      "test_install": "helm upgrade --install --create-namespace --namespace spark-apps --values .github/ci/ci-values.yaml spark-apps spark-apps",
      "test_delete": "kubectl delete ns spark-apps",
      "test_unit": "rm -rf \"$HOME/.local/share/helm/plugins/helm-unittest\" \"$HOME/.local/share/helm/plugins/helm-unittest.git\" && helm plugin install https://github.com/helm-unittest/helm-unittest.git >/dev/null 2>&1 && helm unittest spark-apps",
      "lint": "ct lint --chart-dirs=. --charts=spark-apps --validate-maintainers=false",
      "test_renovate": "LOG_LEVEL=debug renovate --platform=local --dry-run=full"
    }
  }
}